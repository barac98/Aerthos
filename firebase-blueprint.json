{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "The main game state for a user.",
      "type": "object",
      "properties": {
        "floor": { "type": "number" },
        "maxFloor": { "type": "number" },
        "currentRunMaxFloor": { "type": "number" },
        "gold": { "type": "number" },
        "essenceFragments": { "type": "number" },
        "team": {
          "type": "array",
          "items": { "$ref": "paragon" }
        },
        "sunderTree": {
          "type": "object",
          "properties": {
            "luminary": {
              "type": "object",
              "properties": {
                "strike": { "type": "number" },
                "ancestry": { "type": "number" }
              }
            },
            "shadow": {
              "type": "object",
              "properties": {
                "haste": { "type": "number" },
                "thirst": { "type": "number" }
              }
            }
          }
        },
        "celestialAltar": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "celestialAltarSlots": {
          "type": "array",
          "items": { "type": "string" }
        },
        "totalAltarUpgrades": { "type": "number" },
        "inventory": {
          "type": "array",
          "items": { "$ref": "powerCore" }
        },
        "towerAscent": { "type": "number" },
        "playerLevel": { "type": "number" },
        "playerExp": { "type": "number" },
        "hasReset": { "type": "boolean" },
        "totalResets": { "type": "number" },
        "totalInfusions": { "type": "number" },
        "stats": {
          "type": "object",
          "properties": {
            "lastLogin": { "type": "number" }
          }
        }
      },
      "required": [
        "floor", "maxFloor", "gold", "essenceFragments", "team", 
        "sunderTree", "celestialAltar", "celestialAltarSlots", 
        "totalAltarUpgrades", "inventory", "towerAscent", "playerLevel", 
        "playerExp", "hasReset", "totalResets", "totalInfusions"
      ]
    },
    "paragon": {
      "title": "Paragon",
      "description": "A single paragon in the user's team.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "race": { "type": "string" },
        "role": { "type": "string" },
        "level": { "type": "number" },
        "exp": { "type": "number" },
        "expToNext": { "type": "number" },
        "relics": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "powerCore": {
      "title": "Power Core",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tier": { "type": "string" },
        "level": { "type": "number" },
        "bonusDmg": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "userProfile",
      "description": "The user's profile and game state."
    }
  }
}
