rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - currency: object (gold, essence, exp)
    //   - tower: object (currentFloor, maxFloorReached)
    //   - paragons: object (slot1-slot5: {race, level, relics})
    //   - sunderTree: object (nodeID: level)
    //   - altar: object (upgrades: {blessingID: level}, legacyUnlocked: bool)
    //   - stats: object (totalResets, lastLogin)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "baracsammuel@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['floor', 'maxFloor', 'gold', 'essenceFragments', 'team', 'sunderTree', 'celestialAltar', 'celestialAltarSlots', 'totalAltarUpgrades', 'inventory', 'towerAscent', 'playerLevel', 'playerExp', 'hasReset', 'totalResets', 'totalInfusions']) &&
             data.floor is number &&
             data.maxFloor is number &&
             data.gold is number &&
             data.essenceFragments is number &&
             data.team is list &&
             data.sunderTree is map &&
             data.celestialAltar is map &&
             data.celestialAltarSlots is list &&
             data.totalAltarUpgrades is number &&
             data.inventory is list &&
             data.towerAscent is number &&
             data.playerLevel is number &&
             data.playerExp is number &&
             data.hasReset is bool &&
             data.totalResets is number &&
             data.totalInfusions is number;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if (isOwner(userId) && isValidUserProfile(request.resource.data)) || isAdmin();
      allow delete: if isAdmin();
    }
  }
}
